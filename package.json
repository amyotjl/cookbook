{
  "name": "cookbook",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "description": "CookBook — a local-only recipe capture, planning, and cooking app for Android. No accounts, no subscription, all data on-device.",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "expo": "^54.0.0",
    "expo-clipboard": "~8.0.8",
    "expo-keep-awake": "~15.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "node-html-parser": "^6.1.13",
    "parse-ingredient": "^1.2.1",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2",
    "vitest": "^2.0.0"
  }
}
